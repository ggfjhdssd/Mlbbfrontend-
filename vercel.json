{
  "version": 2,
  "builds": [
    { "src": "index.html",  "use": "@vercel/static" },
    { "src": "admin.html",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/admin",      "dest": "/admin.html" },
    { "src": "/",           "dest": "/index.html" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "ALLOWALL" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
